{
  "family": "tourism-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::768781133395:role/LabRole",
  "taskRoleArn": "arn:aws:iam::768781133395:role/LabRole",
  "containerDefinitions": [
    {
      "name": "tourism-container",
      "image": "768781133395.dkr.ecr.us-east-1.amazonaws.com/tourism-booking:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "DB_URL",
          "value": "jdbc:mysql://database-1.ct64jbecah2e.us-east-1.rds.amazonaws.com:3306/tourism_booking?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC"
        },
        {
          "name": "DB_USERNAME",
          "value": "admin"
        },
        {
          "name": "DB_PASSWORD",
          "value": "AwsRds#Booking123"
        },
        {
          "name": "JWT_SECRET",
          "value": "MySecretKeyForJWTTokenGenerationInTourismBookingSystemPleaseChangeInProduction12345"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tourism-booking",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
